{
  "name": "zecur",
  "displayName": "Zero-cursor",
  "publisher": "hastagaming",
  "description": "Zecur AI Agent for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "zecur.startAgent",
        "title": "Zecur: Start Agent"
      },
      {
        "command": "zecur.setApiKey",
        "title": "Zecur: Set API Key"
      },
      {
        "command": "zecur.selectProvider",
        "title": "Zecur: Select Provider"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "highlight.js": "^11.11.1",
    "marked": "^12.0.2",
    "openai": "^4.0.0"
  }
}
